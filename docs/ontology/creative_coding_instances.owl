    <ExpressionGoal rdf:about="http://example.org/creativecoding/instances#personalVisualVocabulary">
        <rdfs:label>Creating a personal visual vocabulary</rdfs:label>
    </ExpressionGoal>

    <ExpressionGoal rdf:about="http://example.org/creativecoding/instances#canvasCreativeSpace">
        <rdfs:label>Understanding the canvas as a creative space</rdfs:label>
    </ExpressionGoal>

    <ExpressionGoal rdf:about="http://example.org/creativecoding/instances#emotionsColor">
        <rdfs:label>Expressing emotions through color</rdfs:label>
    </ExpressionGoal>

    <ExpressionGoal rdf:about="http://example.org/creativecoding/instances#personalColorPalette">
        <rdfs:label>Developing a personal color palette</rdfs:label>
    </ExpressionGoal>

    <ExpressionGoal rdf:about="http://example.org/creativecoding/instances#depthAtmosphere">
        <rdfs:label>Creating depth and atmosphere</rdfs:label>
    </ExpressionGoal>

    <ExpressionGoal rdf:about="http://example.org/creativecoding/instances#visualRelationships">
        <rdfs:label>Exploring visual relationships between elements</rdfs:label>
    </ExpressionGoal>

    <ExpressionGoal rdf:about="http://example.org/creativecoding/instances#staticToLife">
        <rdfs:label>Bringing static compositions to life</rdfs:label>
