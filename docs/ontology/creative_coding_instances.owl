        <hasPrerequisite rdf:resource="http://example.org/creativecoding/instances#variables"/>
        <hasPrerequisite rdf:resource="http://example.org/creativecoding/instances#conditionals"/>
        <enablesCreativeApplication rdf:resource="http://example.org/creativecoding/instances#texturedBackgrounds"/>
        <enablesCreativeApplication rdf:resource="http://example.org/creativecoding/instances#patternDesign"/>
        <enablesCreativeApplication rdf:resource="http://example.org/creativecoding/instances#complexMandalas"/>
        <supportsExpressionGoal rdf:resource="http://example.org/creativecoding/instances#repetitionVariation"/>
        <supportsExpressionGoal rdf:resource="http://example.org/creativecoding/instances#complexFromSimple"/>
        <hasLearningObjective rdf:resource="http://example.org/creativecoding/instances#forLoop"/>
        <hasLearningObjective rdf:resource="http://example.org/creativecoding/instances#nestedLoops"/>
        <hasLearningObjective rdf:resource="http://example.org/creativecoding/instances#whileLoop"/>
    </CreativeCodingConcept>
    
    <!-- Reusable Elements Concept -->
    <CreativeCodingConcept rdf:about="http://example.org/creativecoding/instances#reusableElements">
        <hasIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#string">reusableElements</hasIdentifier>
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reusable Drawing Functions</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Creating modular, reusable elements for complex compositions</hasDescription>
        <hasCategory rdf:resource="http://example.org/creativecoding#patterns"/>
        <hasDifficulty rdf:resource="http://example.org/creativecoding#intermediate"/>
        <hasPrerequisite rdf:resource="http://example.org/creativecoding/instances#simpleDrawing"/>
        <hasPrerequisite rdf:resource="http://example.org/creativecoding/instances#colors"/>
        <hasPrerequisite rdf:resource="http://example.org/creativecoding/instances#variables"/>
        <enablesCreativeApplication rdf:resource="http://example.org/creativecoding/instances#customBrushes"/>
        <enablesCreativeApplication rdf:resource="http://example.org/creativecoding/instances#repeatedCharacterElements"/>
        <enablesCreativeApplication rdf:resource="http://example.org/creativecoding/instances#modularScenes"/>
        <supportsExpressionGoal rdf:resource="http://example.org/creativecoding/instances#personalElementLibrary"/>
        <supportsExpressionGoal rdf:resource="http://example.org/creativecoding/instances#complexScenesModular"/>
        <hasLearningObjective rdf:resource="http://example.org/creativecoding/instances#functionDeclaration"/>
        <hasLearningObjective rdf:resource="http://example.org/creativecoding/instances#returnValues"/>
        <hasLearningObjective rdf:resource="http://example.org/creativecoding/instances#functionCalls"/>
    </CreativeCodingConcept>
    
    <!-- Custom Shapes Concept -->
    <CreativeCodingConcept rdf:about="http://example.org/creativecoding/instances#customShapes">
