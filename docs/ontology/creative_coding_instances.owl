    <!-- 
    //////////////////////////////////////////////////////////////////
    //
    //    Learning Objective Instances
    //
    //////////////////////////////////////////////////////////////////
     -->
     
    <!-- Simple Drawing Learning Objectives -->
    <LearningObjective rdf:about="http://example.org/creativecoding/instances#setupDraw">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">setup and draw</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Core functions</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">setup(), draw()</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">function\s+setup\s*\(\)</hasRegexPattern>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">function\s+draw\s*\(\)</hasRegexPattern>
    </LearningObjective>
 
    <LearningObjective rdf:about="http://example.org/creativecoding/instances#namedColorFill">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">namedColorFill</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Setting the fill color for shapes using CSS color names</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">fill('CSSColor')</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">fill\s*\('[a-zA-Z]+'\)</hasRegexPattern>
    </LearningObjective>
 
    <LearningObjective rdf:about="http://example.org/creativecoding/instances#namedColorStroke">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">namedColorStroke</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Setting the outline color for shapes using CSS color names</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">stroke('CSSColor')</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">stroke\s*\('[a-zA-Z]+'\)</hasRegexPattern>
    </LearningObjective>
 
    <LearningObjective rdf:about="http://example.org/creativecoding/instances#namedColorBackground">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">namedColorBackground</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Setting the background using CSS color names</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">background('CSSColor')</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">background\s*\('[a-zA-Z]+'\)</hasRegexPattern>
    </LearningObjective>
 
    <LearningObjective rdf:about="http://example.org/creativecoding/instances#noFill">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">no fill</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Disabling shape filling</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">noFill()</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">noFill\s*\(\)</hasRegexPattern>
    </LearningObjective>
 
    <LearningObjective rdf:about="http://example.org/creativecoding/instances#noStroke">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">no stroke</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Disabling shape outlines</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">noStroke()</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">noStroke\s*\(\)</hasRegexPattern>
    </LearningObjective>
 
    <LearningObjective rdf:about="http://example.org/creativecoding/instances#ellipse">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ellipse</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Drawing circles and ellipses</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ellipse(x, y, width, height)</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ellipse\s*\([^)]*\)</hasRegexPattern>
    </LearningObjective>
 
    <LearningObjective rdf:about="http://example.org/creativecoding/instances#rectangle">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">rectangle</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Drawing rectangles and squares</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">rect(x, y, width, height)</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">rect\s*\([^)]*\)</hasRegexPattern>
    </LearningObjective>
 
    <LearningObjective rdf:about="http://example.org/creativecoding/instances#line">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">line</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Drawing straight lines between points</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">line(x1, y1, x2, y2)</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">line\s*\([^)]*\)</hasRegexPattern>
    </LearningObjective>
 
    <LearningObjective rdf:about="http://example.org/creativecoding/instances#triangle">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">triangle</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Drawing triangles between three points</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">triangle(x1, y1, x2, y2, x3, y3)</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">triangle\s*\([^)]*\)</hasRegexPattern>
    </LearningObjective>
 
    <LearningObjective rdf:about="http://example.org/creativecoding/instances#point">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">point</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Drawing a single point</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">point(x, y)</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">point\s*\([^)]*\)</hasRegexPattern>
    </LearningObjective>
 
    <LearningObjective rdf:about="http://example.org/creativecoding/instances#quad">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">quad</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Drawing quadrilaterals between four points</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">quad(x1, y1, x2, y2, x3, y3, x4, y4)</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">quad\s*\([^)]*\)</hasRegexPattern>
    </LearningObjective>
 
    <LearningObjective rdf:about="http://example.org/creativecoding/instances#strokeWeight">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">stroke weight</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Setting the thickness of lines and outlines</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">strokeWeight(weight)</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">strokeWeight\s*\([^)]*\)</hasRegexPattern>
    </LearningObjective>
 
    <LearningObjective rdf:about="http://example.org/creativecoding/instances#rectangleMode">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">rectangle mode</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Changing how rectangle coordinates are interpreted (CENTER, CORNER, etc.)</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">rectMode(mode)</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">rectMode\s*\([^)]*\)</hasRegexPattern>
    </LearningObjective>
 
    <LearningObjective rdf:about="http://example.org/creativecoding/instances#ellipseMode">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ellipse mode</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Changing how ellipse coordinates are interpreted (CENTER, RADIUS, etc.)</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ellipseMode(mode)</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ellipseMode\s*\([^)]*\)</hasRegexPattern>
    </LearningObjective>
 
    <!-- Colors Learning Objectives -->
    <LearningObjective rdf:about="http://example.org/creativecoding/instances#fillRGB">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">fill</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Setting the fill color for shapes</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">fill(r, g, b)</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">fill\s*\([0-9]+\s*,\s*[0-9]+\s*,\s*[0-9]+\)</hasRegexPattern>
    </LearningObjective>
 
    <LearningObjective rdf:about="http://example.org/creativecoding/instances#strokeRGB">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">stroke</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Setting the outline color for shapes</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">stroke(r, g, b)</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">stroke\s*\([0-9]+\s*,\s*[0-9]+\s*,\s*[0-9]+\)</hasRegexPattern>
    </LearningObjective>
 
    <LearningObjective rdf:about="http://example.org/creativecoding/instances#backgroundRGB">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">background</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Setting the canvas background color</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">background(r, g, b)</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">background\s*\([0-9]+\s*,\s*[0-9]+\s*,\s*[0-9]+\)</hasRegexPattern>
    </LearningObjective>
 
    <LearningObjective rdf:about="http://example.org/creativecoding/instances#colorMode">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">color mode</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Switching between color systems (RGB, HSB)</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">colorMode(RGB) or colorMode(HSB)</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">colorMode\s*\([^)]*\)</hasRegexPattern>
    </LearningObjective>
 
    <!-- Transparency Learning Objectives -->
    <LearningObjective rdf:about="http://example.org/creativecoding/instances#alphaChannel">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">alpha channel</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Using transparency in colors</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">fill(r, g, b, a), stroke(r, g, b, a), background(r, g, b, a)</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">(fill|stroke|background)\s*\([0-9]+\s*,\s*[0-9]+\s*,\s*[0-9]+\s*,\s*[0-9]+\)</hasRegexPattern>
    </LearningObjective>
 
    <LearningObjective rdf:about="http://example.org/creativecoding/instances#clear">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">clear</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Clearing specific portions of the canvas</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">clear()</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">clear\s*\(\)</hasRegexPattern>
    </LearningObjective>
 
    <LearningObjective rdf:about="http://example.org/creativecoding/instances#eraseMode">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">erase mode</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Erasing portions of already drawn elements</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">erase(), noErase()</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">erase\s*\(\)</hasRegexPattern>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">noErase\s*\(\)</hasRegexPattern>
    </LearningObjective>
 
    <LearningObjective rdf:about="http://example.org/creativecoding/instances#blendMode">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">blend mode</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Controlling how colors blend when layered</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">blendMode(BLEND/ADD/MULTIPLY/etc)</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">blendMode\s*\([^)]*\)</hasRegexPattern>
    </LearningObjective>
 
    <!-- Variables Learning Objectives -->
    <LearningObjective rdf:about="http://example.org/creativecoding/instances#variableDeclaration">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">variable declaration</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Creating and initializing variables</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">let x = 100;</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">let\s+[a-zA-Z_][a-zA-Z0-9_]*\s*=</hasRegexPattern>
    </LearningObjective>
 
    <LearningObjective rdf:about="http://example.org/creativecoding/instances#variableModification">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">variable modification</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Changing variable values over time</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">x = x + 1;</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">^(?!.*let)([a-zA-Z_][a-zA-Z0-9_]*)\s*=</hasRegexPattern>
    </LearningObjective>
 
    <LearningObjective rdf:about="http://example.org/creativecoding/instances#canvasSizeConstants">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">canvas size constants</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Using p5.js canvas size</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">width, height</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">\bwidth\b</hasRegexPattern>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">\bheight\b</hasRegexPattern>
    </LearningObjective>
 
    <LearningObjective rdf:about="http://example.org/creativecoding/instances#mathematicalOperations">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">mathematical operations</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Performing calculations with variables</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">+, -, *, /, %</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">[a-zA-Z0-9_)\]]+\s*[+\-*/%]\s*[a-zA-Z0-9_([]</hasRegexPattern>
    </LearningObjective>
 
    <LearningObjective rdf:about="http://example.org/creativecoding/instances#colorValues">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">color values</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Creating and storing color variables</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">const x = color(...)</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">const\s+[a-zA-Z_][a-zA-Z0-9_]*\s*=\s*color\s*\([^)]*\)</hasRegexPattern>
    </LearningObjective>
 
    <LearningObjective rdf:about="http://example.org/creativecoding/instances#colorInterpolation">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">color interpolation</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Blending between two colors</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">lerpColor(c1, c2, amt)</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">lerpColor\s*\([^)]*\)</hasRegexPattern>
    </LearningObjective>
        
    <LearningObjective rdf:about="http://example.org/creativecoding/instances#ifStatement">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">if statement</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Making basic visual decisions</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">if (condition) { }</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">if\s*\([^{]*\)\s*\{</hasRegexPattern>
    </LearningObjective>

    <LearningObjective rdf:about="http://example.org/creativecoding/instances#ifElseStatement">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">if/else statement</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Creating binary visual alternatives</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">if (condition) { } else { }</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">if\s*\([^{]*\)\s*\{[^}]*\}\s*else\s*\{</hasRegexPattern>
    </LearningObjective>

    <LearningObjective rdf:about="http://example.org/creativecoding/instances#multipleConditions">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">multiple conditions</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Making complex visual decisions with multiple outcomes</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">if (condition) { } else if (anotherCondition) { } else { }</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">else\s+(if\s*\([^{]*\))?\s*\{</hasRegexPattern>
    </LearningObjective>

    <LearningObjective rdf:about="http://example.org/creativecoding/instances#comparisonOperators">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">comparison operators</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Comparing values to make decisions</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">&gt;, &lt;, &gt;=, &lt;=, ==, ===, !=, !==</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">[a-zA-Z0-9_)\]"']+\s*([&lt;&gt;]=?|[=!]=|===|!==)\s*[a-zA-Z0-9_(["']</hasRegexPattern>
    </LearningObjective>

    <LearningObjective rdf:about="http://example.org/creativecoding/instances#logicalOperators">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">logical operators</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Combining multiple conditions</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">&amp;&amp;, ||, !</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">&amp;&amp;</hasRegexPattern>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">\|\|</hasRegexPattern>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">!\s*[a-zA-Z0-9_(]</hasRegexPattern>
    </LearningObjective>

    <!-- Missing Learning Objectives from Randomness Concept -->
    <LearningObjective rdf:about="http://example.org/creativecoding/instances#random">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">random</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Generating random values within a range</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">random(min, max)</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">random\s*\([^)]*\)</hasRegexPattern>
    </LearningObjective>

    <LearningObjective rdf:about="http://example.org/creativecoding/instances#randomSeed">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">random seed</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Creating reproducible randomness</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">randomSeed(seed)</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">randomSeed\s*\([^)]*\)</hasRegexPattern>
    </LearningObjective>

    <LearningObjective rdf:about="http://example.org/creativecoding/instances#perlinNoise">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">perlin noise</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Generating smooth, natural-looking randomness</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">noise(x), noise(x, y), noise(x, y, z)</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">noise\s*\([^)]*\)</hasRegexPattern>
    </LearningObjective>

    <LearningObjective rdf:about="http://example.org/creativecoding/instances#noiseSeed">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">noise seed</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Creating reproducible noise patterns</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">noiseSeed(seed)</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">noiseSeed\s*\([^)]*\)</hasRegexPattern>
    </LearningObjective>

    <!-- Missing Learning Objectives from Animation Concept -->
    <LearningObjective rdf:about="http://example.org/creativecoding/instances#frameRate">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">frame rate</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Controlling animation speed</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">frameRate(fps)</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">frameRate\s*\([^)]*\)</hasRegexPattern>
    </LearningObjective>

    <LearningObjective rdf:about="http://example.org/creativecoding/instances#frameCounter">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">frame counter</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Tracking frames for time-based animation</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">frameCount</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">\bframeCount\b</hasRegexPattern>
    </LearningObjective>

    <LearningObjective rdf:about="http://example.org/creativecoding/instances#milliseconds">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">milliseconds</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Getting elapsed time for precise timing</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">millis()</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">millis\s*\(\)</hasRegexPattern>
    </LearningObjective>

    <!-- Missing Learning Objectives from Interactivity Concept -->
    <LearningObjective rdf:about="http://example.org/creativecoding/instances#mousePosition">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">mouse position</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reading current mouse coordinates</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">mouseX, mouseY</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">\bmouseX\b</hasRegexPattern>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">\bmouseY\b</hasRegexPattern>
    </LearningObjective>

    <LearningObjective rdf:about="http://example.org/creativecoding/instances#previousMousePosition">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">previous mouse position</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Tracking mouse movement between frames</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">pmouseX, pmouseY</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">\bpmouseX\b</hasRegexPattern>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">\bpmouseY\b</hasRegexPattern>
    </LearningObjective>

    <LearningObjective rdf:about="http://example.org/creativecoding/instances#mouseButtonState">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">mouse button state</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Detecting if mouse button is down</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">mouseIsPressed</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">\bmouseIsPressed\b</hasRegexPattern>
    </LearningObjective>

    <LearningObjective rdf:about="http://example.org/creativecoding/instances#keyState">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">key state</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Detecting if any key is pressed</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">keyIsPressed</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">\bkeyIsPressed\b</hasRegexPattern>
    </LearningObjective>

    <LearningObjective rdf:about="http://example.org/creativecoding/instances#currentKey">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">current key</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Identifying which key is being pressed</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">key</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">\bkey\b</hasRegexPattern>
    </LearningObjective>

    <LearningObjective rdf:about="http://example.org/creativecoding/instances#keyCode">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">key code</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reading special keys like arrows and modifiers</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">keyCode</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">\bkeyCode\b</hasRegexPattern>
    </LearningObjective>

    <!-- Missing Learning Objectives from Repetition Concept -->
    <LearningObjective rdf:about="http://example.org/creativecoding/instances#forLoop">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">for loop</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Creating repetition with counter variables</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">for (let i = 0; i &lt; n; i++) { }</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">for\s*\([^;]*;[^;]*;[^)]*\)\s*\{</hasRegexPattern>
    </LearningObjective>

    <LearningObjective rdf:about="http://example.org/creativecoding/instances#nestedLoops">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">nested loops</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Creating 2D grids and complex patterns</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">for (let x = 0; x &lt; width; x += 10) { for (let y = 0; y &lt; height; y += 10) { } }</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">for\s*\([^{]*\)\s*\{[^{]*for\s*\([^{]*\)\s*\{</hasRegexPattern>
    </LearningObjective>

    <LearningObjective rdf:about="http://example.org/creativecoding/instances#whileLoop">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">while loop</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Creating repetition based on conditions</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">while (condition) { }</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">while\s*\([^{]*\)\s*\{</hasRegexPattern>
    </LearningObjective>

    <!-- Missing Learning Objectives from Reusable Elements Concept -->
    <LearningObjective rdf:about="http://example.org/creativecoding/instances#functionDeclaration">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">function declaration</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Creating custom drawing routines</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">function drawChar(x, y, size) { }</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">function (?!.*setup|draw)[a-zA-Z_][a-zA-Z0-9_]*\s*\([^)]*\)\s*\{</hasRegexPattern>
    </LearningObjective>

    <LearningObjective rdf:about="http://example.org/creativecoding/instances#returnValues">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">return values</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Returning results from functions</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">return value;</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">return\s*\(</hasRegexPattern>
    </LearningObjective>

    <LearningObjective rdf:about="http://example.org/creativecoding/instances#functionCalls">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">function calls</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Using custom functions to create repeated elements</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">drawChar(100, 200, 50);</hasCode>
    </LearningObjective>

    <!-- Missing Learning Objectives from Custom Shapes Concept -->
    <LearningObjective rdf:about="http://example.org/creativecoding/instances#beginEndShape">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">begin/end shape</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Creating custom polygon shapes</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">beginShape(), endShape()</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">beginShape\s*\(</hasRegexPattern>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">endShape\s*\(</hasRegexPattern>
    </LearningObjective>

    <LearningObjective rdf:about="http://example.org/creativecoding/instances#vertex">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">vertex</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Adding points to custom shapes</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">vertex(x, y)</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">vertex\s*\(</hasRegexPattern>
    </LearningObjective>

    <LearningObjective rdf:about="http://example.org/creativecoding/instances#curveVertex">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">curve vertex</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Creating smooth curved shapes</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">curveVertex(x, y)</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">curveVertex\s*\(</hasRegexPattern>
    </LearningObjective>

    <LearningObjective rdf:about="http://example.org/creativecoding/instances#bezierVertex">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">bezier vertex</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Creating precise Bézier curves</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">bezierVertex(x2, y2, x3, y3, x4, y4)</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">bezierVertex\s*\(</hasRegexPattern>
    </LearningObjective>

    <LearningObjective rdf:about="http://example.org/creativecoding/instances#arc">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">arc</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Drawing partial circles and ellipses</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">arc(x, y, w, h, start, stop)</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">arc\s*\(</hasRegexPattern>
    </LearningObjective>

    <!-- Missing Learning Objectives from Transformations Concept -->
    <LearningObjective rdf:about="http://example.org/creativecoding/instances#translate">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">translate</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Moving the coordinate system</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">translate(x, y)</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">translate\s*\([^)]*\)</hasRegexPattern>
    </LearningObjective>

    <LearningObjective rdf:about="http://example.org/creativecoding/instances#rotate">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">rotate</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Rotating the coordinate system</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">rotate(angle)</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">rotate\s*\([^)]*\)</hasRegexPattern>
    </LearningObjective>

    <LearningObjective rdf:about="http://example.org/creativecoding/instances#scale">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">scale</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Scaling the coordinate system</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">scale(x, y)</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">scale\s*\([^)]*\)</hasRegexPattern>
    </LearningObjective>

    <LearningObjective rdf:about="http://example.org/creativecoding/instances#transformationState">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">transformation state</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Saving and restoring transformation states</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">push(), pop()</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">push\s*\(\)</hasRegexPattern>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">pop\s*\(\)</hasRegexPattern>
    </LearningObjective>

    <LearningObjective rdf:about="http://example.org/creativecoding/instances#angleMode">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">angle mode</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Setting units for rotation angles</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">angleMode(RADIANS) or angleMode(DEGREES)</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">angleMode\s*\([^)]*\)</hasRegexPattern>
    </LearningObjective>

    <!-- Missing Learning Objectives from Collections Concept -->
    <LearningObjective rdf:about="http://example.org/creativecoding/instances#arrayCreation">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">array creation</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Creating collections of visual elements</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">let points = [];</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">let\s+[a-zA-Z_][a-zA-Z0-9_]*\s*=\s*\[\]</hasRegexPattern>
    </LearningObjective>

    <LearningObjective rdf:about="http://example.org/creativecoding/instances#arrayAccess">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">array access</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Accessing individual elements in a collection</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">points[0]</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">[a-zA-Z_][a-zA-Z0-9_]*\.length</hasRegexPattern>
    </LearningObjective>

    <LearningObjective rdf:about="http://example.org/creativecoding/instances#arrayIteration">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">array iteration</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Working with all elements in a collection</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">for (let i = 0; i &lt; points.length; i++) { }</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">for\s*\([^;]*;[^;]*\.length[^;]*;[^)]*\)</hasRegexPattern>
    </LearningObjective>

    <LearningObjective rdf:about="http://example.org/creativecoding/instances#arrayOfObjects">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">array of objects</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Creating collections of complex visual elements</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">let particles = [{x: 0, y: 0}];</hasCode>
    </LearningObjective>
        
    <LearningObjective rdf:about="http://example.org/creativecoding/instances#arrayMethods">
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">array methods</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Modifying and querying collections</hasDescription>
        <hasCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">push(), splice(), length</hasCode>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">[a-zA-Z_][a-zA-Z0-9_]*\.push\s*\(</hasRegexPattern>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">[a-zA-Z_][a-zA-Z0-9_]*\.splice\s*\(</hasRegexPattern>
        <hasRegexPattern rdf:datatype="http://www.w3.org/2001/XMLSchema#string">[a-zA-Z_][a-zA-Z0-9_]*\s*\[[^\]]*\]</hasRegexPattern>
    </LearningObjective>

