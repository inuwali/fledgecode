<?xml version="1.0"?>
<rdf:RDF xmlns="http://example.org/creativecoding#"
     xml:base="http://example.org/creativecoding"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:dc="http://purl.org/dc/elements/1.1/">
    <owl:Ontology rdf:about="http://example.org/creativecoding/instances">
        <owl:imports rdf:resource="http://example.org/creativecoding"/>
        <dc:title>Creative Coding Concept Instances</dc:title>
        <dc:description>Individual instances of creative coding concepts, learning objectives, and artistic pathways</dc:description>
        <owl:versionInfo>1.0</owl:versionInfo>
    </owl:Ontology>

    <!-- 
    //////////////////////////////////////////////////////////////////
    //
    //    Creative Coding Concept Instances
    //
    //////////////////////////////////////////////////////////////////
     -->

    <!-- Simple Drawing Concept -->
    <CreativeCodingConcept rdf:about="http://example.org/creativecoding/instances#simpleDrawing">
        <hasIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#string">simpleDrawing</hasIdentifier>
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Simple Drawing</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Creating fundamental visual elements like circles, rectangles, and lines</hasDescription>
        <hasCategory rdf:resource="http://example.org/creativecoding#basics"/>
        <hasDifficulty rdf:resource="http://example.org/creativecoding#beginner"/>
        <enablesCreativeApplication rdf:resource="http://example.org/creativecoding/instances#abstractCompositions"/>
        <enablesCreativeApplication rdf:resource="http://example.org/creativecoding/instances#geometricPatterns"/>
        <enablesCreativeApplication rdf:resource="http://example.org/creativecoding/instances#characterDesign"/>
        <supportsExpressionGoal rdf:resource="http://example.org/creativecoding/instances#personalVisualVocabulary"/>
        <supportsExpressionGoal rdf:resource="http://example.org/creativecoding/instances#canvasCreativeSpace"/>
        <hasLearningObjective rdf:resource="http://example.org/creativecoding/instances#setupDraw"/>
        <hasLearningObjective rdf:resource="http://example.org/creativecoding/instances#namedColorFill"/>
        <hasLearningObjective rdf:resource="http://example.org/creativecoding/instances#namedColorStroke"/>
        <hasLearningObjective rdf:resource="http://example.org/creativecoding/instances#namedColorBackground"/>
        <hasLearningObjective rdf:resource="http://example.org/creativecoding/instances#noFill"/>
        <hasLearningObjective rdf:resource="http://example.org/creativecoding/instances#noStroke"/>
        <hasLearningObjective rdf:resource="http://example.org/creativecoding/instances#ellipse"/>
        <hasLearningObjective rdf:resource="http://example.org/creativecoding/instances#rectangle"/>
        <hasLearningObjective rdf:resource="http://example.org/creativecoding/instances#line"/>
        <hasLearningObjective rdf:resource="http://example.org/creativecoding/instances#triangle"/>
        <hasLearningObjective rdf:resource="http://example.org/creativecoding/instances#point"/>
        <hasLearningObjective rdf:resource="http://example.org/creativecoding/instances#quad"/>
        <hasLearningObjective rdf:resource="http://example.org/creativecoding/instances#strokeWeight"/>
        <hasLearningObjective rdf:resource="http://example.org/creativecoding/instances#rectangleMode"/>
        <hasLearningObjective rdf:resource="http://example.org/creativecoding/instances#ellipseMode"/>
    </CreativeCodingConcept>
    
    <!-- Colors Concept -->
    <CreativeCodingConcept rdf:about="http://example.org/creativecoding/instances#colors">
        <hasIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#string">colors</hasIdentifier>
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Colors and Palettes</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Using numeric definitions for colors to create precise hues</hasDescription>
        <hasCategory rdf:resource="http://example.org/creativecoding#basics"/>
        <hasDifficulty rdf:resource="http://example.org/creativecoding#beginner"/>
        <hasPrerequisite rdf:resource="http://example.org/creativecoding/instances#simpleDrawing"/>
        <enablesCreativeApplication rdf:resource="http://example.org/creativecoding/instances#emotiveColorSchemes"/>
        <enablesCreativeApplication rdf:resource="http://example.org/creativecoding/instances#gradients"/>
        <enablesCreativeApplication rdf:resource="http://example.org/creativecoding/instances#colorTheoryExploration"/>
        <supportsExpressionGoal rdf:resource="http://example.org/creativecoding/instances#emotionsColor"/>
        <supportsExpressionGoal rdf:resource="http://example.org/creativecoding/instances#personalColorPalette"/>
        <hasLearningObjective rdf:resource="http://example.org/creativecoding/instances#fillRGB"/>
        <hasLearningObjective rdf:resource="http://example.org/creativecoding/instances#strokeRGB"/>
        <hasLearningObjective rdf:resource="http://example.org/creativecoding/instances#backgroundRGB"/>
        <hasLearningObjective rdf:resource="http://example.org/creativecoding/instances#colorMode"/>
    </CreativeCodingConcept>
    
    <!-- Transparency Concept -->
    <CreativeCodingConcept rdf:about="http://example.org/creativecoding/instances#transparency">
        <hasIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#string">transparency</hasIdentifier>
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Transparency and Layering</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Creating depth through transparent layers</hasDescription>
        <hasCategory rdf:resource="http://example.org/creativecoding#basics"/>
        <hasDifficulty rdf:resource="http://example.org/creativecoding#beginnerIntermediate"/>
        <hasPrerequisite rdf:resource="http://example.org/creativecoding/instances#colors"/>
        <enablesCreativeApplication rdf:resource="http://example.org/creativecoding/instances#atmosphericEffects"/>
        <enablesCreativeApplication rdf:resource="http://example.org/creativecoding/instances#overlappingCompositions"/>
        <enablesCreativeApplication rdf:resource="http://example.org/creativecoding/instances#watercolorTextures"/>
        <supportsExpressionGoal rdf:resource="http://example.org/creativecoding/instances#depthAtmosphere"/>
        <supportsExpressionGoal rdf:resource="http://example.org/creativecoding/instances#visualRelationships"/>
        <hasLearningObjective rdf:resource="http://example.org/creativecoding/instances#alphaChannel"/>
        <hasLearningObjective rdf:resource="http://example.org/creativecoding/instances#clear"/>
        <hasLearningObjective rdf:resource="http://example.org/creativecoding/instances#eraseMode"/>
        <hasLearningObjective rdf:resource="http://example.org/creativecoding/instances#blendMode"/>
    </CreativeCodingConcept>
    
    <!-- Variables Concept -->
    <CreativeCodingConcept rdf:about="http://example.org/creativecoding/instances#variables">
        <hasIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#string">variables</hasIdentifier>
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Variables</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Using variables to represent values</hasDescription>
        <hasCategory rdf:resource="http://example.org/creativecoding#basics"/>
        <hasDifficulty rdf:resource="http://example.org/creativecoding#beginner"/>
        <hasPrerequisite rdf:resource="http://example.org/creativecoding/instances#simpleDrawing"/>
        <hasPrerequisite rdf:resource="http://example.org/creativecoding/instances#colors"/>
        <enablesCreativeApplication rdf:resource="http://example.org/creativecoding/instances#animatedElements"/>
        <enablesCreativeApplication rdf:resource="http://example.org/creativecoding/instances#growingShrinkingShapes"/>
        <enablesCreativeApplication rdf:resource="http://example.org/creativecoding/instances#movingObjects"/>
        <supportsExpressionGoal rdf:resource="http://example.org/creativecoding/instances#staticToLife"/>
        <supportsExpressionGoal rdf:resource="http://example.org/creativecoding/instances#changeExpressive"/>
        <hasLearningObjective rdf:resource="http://example.org/creativecoding/instances#variableDeclaration"/>
        <hasLearningObjective rdf:resource="http://example.org/creativecoding/instances#variableModification"/>
        <hasLearningObjective rdf:resource="http://example.org/creativecoding/instances#canvasSizeConstants"/>
        <hasLearningObjective rdf:resource="http://example.org/creativecoding/instances#mathematicalOperations"/>
        <hasLearningObjective rdf:resource="http://example.org/creativecoding/instances#colorValues"/>
        <hasLearningObjective rdf:resource="http://example.org/creativecoding/instances#colorInterpolation"/>
    </CreativeCodingConcept>
    
    <!-- Conditionals Concept -->
    <CreativeCodingConcept rdf:about="http://example.org/creativecoding/instances#conditionals">
        <hasIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#string">conditionals</hasIdentifier>
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Visual Decision Making</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Creating different visuals based on conditions</hasDescription>
        <hasCategory rdf:resource="http://example.org/creativecoding#expressivity"/>
        <hasDifficulty rdf:resource="http://example.org/creativecoding#intermediate"/>
        <hasPrerequisite rdf:resource="http://example.org/creativecoding/instances#variables"/>
        <enablesCreativeApplication rdf:resource="http://example.org/creativecoding/instances#responsiveElements"/>
        <enablesCreativeApplication rdf:resource="http://example.org/creativecoding/instances#dayNightTransitions"/>
        <enablesCreativeApplication rdf:resource="http://example.org/creativecoding/instances#moodBasedColorSchemes"/>
        <supportsExpressionGoal rdf:resource="http://example.org/creativecoding/instances#changeAdapt"/>
        <supportsExpressionGoal rdf:resource="http://example.org/creativecoding/instances#visualCauseEffect"/>
        <hasLearningObjective rdf:resource="http://example.org/creativecoding/instances#ifStatement"/>
        <hasLearningObjective rdf:resource="http://example.org/creativecoding/instances#ifElseStatement"/>
        <hasLearningObjective rdf:resource="http://example.org/creativecoding/instances#multipleConditions"/>
        <hasLearningObjective rdf:resource="http://example.org/creativecoding/instances#comparisonOperators"/>
        <hasLearningObjective rdf:resource="http://example.org/creativecoding/instances#logicalOperators"/>
    </CreativeCodingConcept>
    
    <!-- Randomness Concept -->
    <CreativeCodingConcept rdf:about="http://example.org/creativecoding/instances#randomness">
        <hasIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#string">randomness</hasIdentifier>
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Creative Randomness</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Using chance to create organic variety and spontaneity</hasDescription>
        <hasCategory rdf:resource="http://example.org/creativecoding#expressivity"/>
        <hasDifficulty rdf:resource="http://example.org/creativecoding#beginnerIntermediate"/>
        <hasPrerequisite rdf:resource="http://example.org/creativecoding/instances#variables"/>
        <enablesCreativeApplication rdf:resource="http://example.org/creativecoding/instances#organicPatterns"/>
        <enablesCreativeApplication rdf:resource="http://example.org/creativecoding/instances#generativeArt"/>
        <enablesCreativeApplication rdf:resource="http://example.org/creativecoding/instances#naturalVariation"/>
        <supportsExpressionGoal rdf:resource="http://example.org/creativecoding/instances#controlChance"/>
        <supportsExpressionGoal rdf:resource="http://example.org/creativecoding/instances#uniqueOutputs"/>
        <hasLearningObjective rdf:resource="http://example.org/creativecoding/instances#random"/>
        <hasLearningObjective rdf:resource="http://example.org/creativecoding/instances#randomSeed"/>
        <hasLearningObjective rdf:resource="http://example.org/creativecoding/instances#perlinNoise"/>
        <hasLearningObjective rdf:resource="http://example.org/creativecoding/instances#noiseSeed"/>
    </CreativeCodingConcept>
    
    <!-- Animation Concept -->
    <CreativeCodingConcept rdf:about="http://example.org/creativecoding/instances#animation">
        <hasIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#string">animation</hasIdentifier>
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Basic Animation</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Creating movement over time</hasDescription>
        <hasCategory rdf:resource="http://example.org/creativecoding#expressivity"/>
        <hasDifficulty rdf:resource="http://example.org/creativecoding#intermediate"/>
        <hasPrerequisite rdf:resource="http://example.org/creativecoding/instances#variables"/>
        <enablesCreativeApplication rdf:resource="http://example.org/creativecoding/instances#movingCharacters"/>
        <enablesCreativeApplication rdf:resource="http://example.org/creativecoding/instances#kineticTypography"/>
        <enablesCreativeApplication rdf:resource="http://example.org/creativecoding/instances#animatedPatterns"/>
        <supportsExpressionGoal rdf:resource="http://example.org/creativecoding/instances#movementIdeas"/>
        <supportsExpressionGoal rdf:resource="http://example.org/creativecoding/instances#visualNarratives"/>
        <hasLearningObjective rdf:resource="http://example.org/creativecoding/instances#frameRate"/>
        <hasLearningObjective rdf:resource="http://example.org/creativecoding/instances#frameCounter"/>
        <hasLearningObjective rdf:resource="http://example.org/creativecoding/instances#milliseconds"/>
    </CreativeCodingConcept>
    
    <!-- Interactivity Concept -->
    <CreativeCodingConcept rdf:about="http://example.org/creativecoding/instances#interactivity">
        <hasIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#string">interactivity</hasIdentifier>
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">User Interaction</hasName>
