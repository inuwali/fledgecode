        <hasLearningObjective rdf:resource="http://example.org/creativecoding/instances#previousMousePosition"/>
        <hasLearningObjective rdf:resource="http://example.org/creativecoding/instances#mouseButtonState"/>
        <hasLearningObjective rdf:resource="http://example.org/creativecoding/instances#keyState"/>
        <hasLearningObjective rdf:resource="http://example.org/creativecoding/instances#currentKey"/>
        <hasLearningObjective rdf:resource="http://example.org/creativecoding/instances#keyCode"/>
    </CreativeCodingConcept>
    
    <!-- Repetition Concept -->
    <CreativeCodingConcept rdf:about="http://example.org/creativecoding/instances#repetition">
        <hasIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#string">repetition</hasIdentifier>
        <hasName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Patterns and Repetition</hasName>
        <hasDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Creating complex visuals through repeated elements</hasDescription>
        <hasCategory rdf:resource="http://example.org/creativecoding#patterns"/>
